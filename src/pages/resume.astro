---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageSettings, siteConfig } from "../config/site";

const page = getPageSettings("resume");
if (!page.published) {
  return Astro.redirect("/");
}

const resume = siteConfig.resume;
---

<BaseLayout title={page.title} description={page.description}>
  <section class="resume-hero">
    <div class="page-intro narrow">
      <p class="eyebrow">Resume</p>
      <h1>Resume, built into the site.</h1>
      <p class="lede">
        The HTML version is embedded for quick reading, while the PDF stays one click away
        for downloading or sharing.
      </p>
    </div>

    <aside class="resume-summary-panel" aria-label="Resume status">
      <span class="resume-version-kicker">Version</span>
      <strong>{resume.status}</strong>
      <span>{resume.versionNote}</span>
    </aside>
  </section>

  <section class="surface-card resume-card">
    <div class="resume-toolbar">
      <div>
        <p class="eyebrow">Document preview</p>
        <h2>Readable here, portable as a PDF.</h2>
      </div>

      <div class="resume-actions">
        <a class="button button-ghost" href={resume.htmlHref}>
          Open HTML
        </a>
        <a class="button" href={resume.pdfHref} download>
          Download PDF
        </a>
      </div>
    </div>

    <div class="resume-preview-shell">
      <iframe
        class="resume-frame"
        src={resume.htmlHref}
        title="HTML resume preview"
        loading="lazy"
      ></iframe>
    </div>
  </section>
</BaseLayout>
