---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageSettings, siteConfig } from "../config/site";

const page = getPageSettings("resume");
if (!page.published) {
  return Astro.redirect("/");
}

const resume = siteConfig.resume;
---

<BaseLayout title={page.title} description={page.description}>
  <section class="page-intro narrow">
    <p class="eyebrow">Resume</p>
    <h1>Resume, built into the site.</h1>
    <p class="lede">
      The page uses the HTML version of the resume for a cleaner read, with the PDF kept
      one click away for downloading or sharing.
    </p>
  </section>

  <section class="surface-card resume-card">
    <div class="resume-toolbar">
      <div class="resume-version-card" aria-label="Resume version">
        <span class="resume-version-kicker">Version</span>
        <strong>{resume.status}</strong>
        <span>{resume.versionNote}</span>
      </div>

      <div class="resume-actions">
        <a class="button" href={resume.pdfHref} download>
          Download PDF
        </a>
      </div>
    </div>

    <div class="resume-preview-shell">
      <iframe
        class="resume-frame"
        src={resume.htmlHref}
        title="HTML resume preview"
        loading="lazy"
      ></iframe>
    </div>
  </section>
</BaseLayout>
