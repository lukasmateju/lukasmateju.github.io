---
import { getCollection } from "astro:content";
import BentoBox from "../components/BentoBox.astro";
import ProjectCard from "../components/ProjectCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.rank - right.data.rank
);
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 4);

const currentFocus = [
  "Building out this portfolio so it feels personal instead of template-first.",
  "Collecting project write-ups that explain both the process and the outcome.",
  "Keeping the stack simple enough to learn from and easy to maintain."
];

const snapshot = [
  "Industrial and Operations Engineering + Computer Science",
  "Hands-on engineering, software, and team-driven projects",
  "Interested in clubs, tools, movies, and side quests that become real builds"
];

const quickLinks = [
  { label: "Projects", href: "/projects" },
  { label: "About", href: "/about" },
  { label: "Resume", href: "/resume" }
];
---

<BaseLayout
  title="Lukas Mateju"
  description="Portfolio site for Lukas Mateju with projects, background, and resume."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Engineering, systems, and personal projects</p>
      <h1>Building a portfolio that feels more like a person than a template.</h1>
      <p class="lede">
        This version of the site is a fresh Astro rebuild: lighter, more personal, and set
        up so new project write-ups are easy to add over time.
      </p>

      <div class="button-row">
        <a class="button" href="/projects">Browse projects</a>
        <a class="button button-ghost" href="/about">Read the about page</a>
      </div>
    </div>

    <div class="hero-panel">
      <div class="hero-badge">LM</div>
      <p class="hero-panel-label">Current build phase</p>
      <h2>Starter structure first, content polish second.</h2>
      <p>
        The layout, project collection, and deploy workflow are in place so the next passes
        can focus on real writing, visuals, and details.
      </p>
    </div>
  </section>

  <section class="bento-grid" aria-label="Quick overview">
    <BentoBox title="Current Focus" eyebrow="Now" accent="mint">
      <ul class="stack-list">
        {currentFocus.map((item) => <li>{item}</li>)}
      </ul>
    </BentoBox>

    <BentoBox title="Snapshot" eyebrow="At a glance" accent="sand">
      <ul class="stack-list">
        {snapshot.map((item) => <li>{item}</li>)}
      </ul>
    </BentoBox>

    <BentoBox title="Explore" eyebrow="Jump in" accent="clay">
      <div class="button-cluster">
        {quickLinks.map((link) => (
          <a class="chip-link" href={link.href}>
            {link.label}
          </a>
        ))}
      </div>
    </BentoBox>
  </section>

  <section class="section-heading">
    <div>
      <p class="eyebrow">Featured work</p>
      <h2>Project cards wired to Markdown content</h2>
    </div>
    <a class="text-link" href="/projects">
      View all projects
    </a>
  </section>

  <section class="project-grid">
    {featuredProjects.map((project) => <ProjectCard project={project} />)}
  </section>
</BaseLayout>
