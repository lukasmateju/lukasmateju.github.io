---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BentoBox from "../components/BentoBox.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getPageSettings } from "../config/site";
import { isProjectVisibleOnHome, sortProjectsByRank } from "../lib/projects";

const page = getPageSettings("home");

const homeProjects = sortProjectsByRank(await getCollection("projects")).filter(
  isProjectVisibleOnHome
);

const focusAreas = [
  "Operations research",
  "Human-centered systems",
  "Manufacturing and hardware",
  "Practical software tools"
];

const statusCards = [
  {
    title: "Now",
    eyebrow: "Current",
    text: "University of Michigan IOE + CS work, research follow-through, and portfolio rebuild."
  },
  {
    title: "Best Fit",
    eyebrow: "Direction",
    text: "Projects where models, tools, people, and physical constraints all have to agree."
  },
  {
    title: "Site Goal",
    eyebrow: "Portfolio",
    text: "A compact place to understand the work quickly, then dig into the details when useful."
  }
];
---

<BaseLayout title={page.title} description={page.description}>
  <section class="home-hero">
    <div class="home-hero-copy">
      <p class="eyebrow">Industrial engineering + computer science</p>
      <h1>Building useful systems from messy constraints.</h1>
      <p class="lede">
        I am Lukas Mateju, a University of Michigan student working across operations,
        software, research, and hands-on engineering. This portfolio is being shaped into a
        cleaner record of the projects, decisions, and systems I care about.
      </p>
      <div class="button-row">
        <a class="button" href="/resume">View resume</a>
        <a class="button button-ghost" href="/about">About me</a>
      </div>
    </div>

    <aside class="home-hero-visual" aria-label="Profile summary">
      <img class="hero-portrait" src="/images/Headshot-W26.png" alt="Lukas Mateju" />
      <div class="hero-stat-grid">
        <div>
          <span>UMich</span>
          <strong>IOE + CS</strong>
        </div>
        <div>
          <span>Focus</span>
          <strong>Systems</strong>
        </div>
      </div>
    </aside>
  </section>

  <section class="home-strip" aria-label="Focus areas">
    {focusAreas.map((area) => <span>{area}</span>)}
  </section>

  <section class="bento-grid home-bento">
    {statusCards.map((card, index) => (
      <BentoBox
        title={card.title}
        eyebrow={card.eyebrow}
        accent={index === 1 ? "blue" : index === 2 ? "clay" : "sand"}
      >
        <p>{card.text}</p>
      </BentoBox>
    ))}
  </section>

  <section class="section-heading">
    <div>
      <p class="eyebrow">Selected work</p>
      <h2>Project stories will live here.</h2>
    </div>
    <a class="text-link" href="/projects">Project archive</a>
  </section>

  {
    homeProjects.length > 0 ? (
      <section class="project-grid">
        {homeProjects.slice(0, 4).map((project) => <ProjectCard project={project} />)}
      </section>
    ) : (
      <section class="surface-card empty-feature">
        <div>
          <p class="eyebrow">In progress</p>
          <h3>The project cards are ready for published write-ups.</h3>
        </div>
        <p>
          The layout is already wired to the Markdown project collection. Once individual
          projects are marked public, they will appear here automatically.
        </p>
      </section>
    )
  }
</BaseLayout>
