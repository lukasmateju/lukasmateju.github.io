---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getPageSettings } from "../config/site";
import {
  isProjectPublished,
  isProjectVisibleInArchive,
  sortProjectsByRank
} from "../lib/projects";

const page = getPageSettings("projects");
if (!page.published) {
  return Astro.redirect("/");
}

const projects = sortProjectsByRank(await getCollection("projects")).filter(
  isProjectVisibleInArchive
);
const featuredProjects = projects.filter((project) => project.data.featured);
const hiddenProjectCount = (await getCollection("projects")).filter(
  (project) => !isProjectPublished(project) || !project.data.showInArchive
).length;
---

<BaseLayout
  title={page.title}
  description={page.description}
>
  <section class="page-intro">
    <p class="eyebrow">Projects</p>
    <h1>All projects live in one collection now.</h1>
    <p class="lede">
      Each card is backed by a Markdown file in <code>src/content/projects</code>, which keeps
      the writing workflow simple and makes it easy to add detail pages later.
      {hiddenProjectCount > 0 && (
        <span>
          {" "}
          {hiddenProjectCount} draft or hidden project{hiddenProjectCount === 1 ? "" : "s"} are
          excluded from this public view.
        </span>
      )}
    </p>
  </section>

  <section class="section-heading">
    <div>
      <p class="eyebrow">Featured</p>
      <h2>The first set to polish</h2>
    </div>
  </section>

  <section class="project-grid">
    {featuredProjects.map((project) => <ProjectCard project={project} />)}
  </section>

  <section class="section-heading section-heading-spaced">
    <div>
      <p class="eyebrow">Collection</p>
      <h2>Everything in the project archive</h2>
    </div>
  </section>

  <section class="project-grid">
    {projects.map((project) => <ProjectCard project={project} compact />)}
  </section>
</BaseLayout>
