---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageSettings } from "../config/site";

const page = getPageSettings("about");
if (!page.published) {
  return Astro.redirect("/");
}

const values = [
  "I like projects that mix systems thinking with hands-on execution.",
  "I want this site to make room for technical work and the personal context around it.",
  "The structure should stay simple enough that updating it is never a chore."
];

const interests = [
  "Engineering teams and long-running build projects",
  "Coursework that turns into practical tools or experiments",
  "Communities, clubs, and side interests that make a portfolio feel human"
];
---

<BaseLayout title={page.title} description={page.description}>
  <section class="page-intro narrow">
    <p class="eyebrow">About</p>
    <h1>A better place for the story behind the work.</h1>
    <p class="lede">
      The old portfolio had the right ingredients but not much personality. This rebuild is
      meant to combine projects, context, interests, and a clearer sense of who the site is
      actually about.
    </p>
  </section>

  <section class="two-column">
    <article class="surface-card">
      <h2>What I want this site to do</h2>
      <ul class="stack-list">
        {values.map((item) => <li>{item}</li>)}
      </ul>
    </article>

    <article class="surface-card">
      <h2>What tends to show up in my work</h2>
      <ul class="stack-list">
        {interests.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>

  <section class="surface-card prose-block">
    <h2>Next pass</h2>
    <p>
      This page is ready for real copy when you want it. A good next step is pulling over the
      strongest details from your current site, then trimming them into a tighter and more
      personal narrative instead of rebuilding the old page structure one-for-one.
    </p>
  </section>
</BaseLayout>
