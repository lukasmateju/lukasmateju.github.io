---
interface Props {
  title: string;
  eyebrow?: string;
  href?: string;
  accent?: "sand" | "mint" | "clay" | "ink";
  className?: string;
}

const {
  title,
  eyebrow,
  href,
  accent = "sand",
  className = ""
} = Astro.props;
const Tag = href ? "a" : "section";
---

<Tag class:list={["bento-box", accent, className]} href={href}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h3>{title}</h3>
  <div class="bento-content">
    <slot />
  </div>
</Tag>
